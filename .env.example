# Copy to .env and fill in. All optional for local dev.
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# Email (optional). Without these, notifications print to the server console.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=SwitchBored <you@gmail.com>
